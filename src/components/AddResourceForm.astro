---
import resourceData from '../data/resources.json';

const accessModels = resourceData.taxonomies.access_model;
const origins = resourceData.taxonomies.origin;
const publisherTypes = resourceData.taxonomies.publisher_type;
const domains = resourceData.taxonomies.domain;
const contentTypes = resourceData.taxonomies.content_type;
const topics = resourceData.taxonomies.topic;
---

<div class="add-resource-form">
  <h2>Add New Resource</h2>
  <form id="addResourceForm">
    <!-- Source URL (required) -->
    <div class="form-group">
      <label for="source">Source URL *</label>
      <input
        type="url"
        id="source"
        name="source"
        required
        placeholder="https://..."
      />
    </div>

    <!-- Comments (optional) -->
    <div class="form-group">
      <label for="comments">Comments</label>
      <textarea
        id="comments"
        name="comments"
        rows="3"
        placeholder="Notes about this resource..."
      ></textarea>
    </div>

    <!-- Trust level (1-5) -->
    <div class="form-group">
      <label for="trust_level">Trust Level (1-5) *</label>
      <input
        type="number"
        id="trust_level"
        name="trust_level"
        min="1"
        max="5"
        step="1"
        required
        value="3"
      />
    </div>

    <!-- Access Model (multiples) -->
    <div class="form-group">
      <label>Access Model *</label>
      <div class="checkbox-group">
        {accessModels.map(value => (
          <label class="checkbox-label">
            <input type="checkbox" name="access_model" value={value} />
            {value}
          </label>
        ))}
      </div>
    </div>

    <!-- Origin (multiples) -->
    <div class="form-group">
      <label>Origin *</label>
      <div class="checkbox-group">
        {origins.map(value => (
          <label class="checkbox-label">
            <input type="checkbox" name="origin" value={value} />
            {value}
          </label>
        ))}
      </div>
    </div>

    <!-- Publisher Type (multiples) -->
    <div class="form-group">
      <label>Publisher Type *</label>
      <div class="checkbox-group">
        {publisherTypes.map(value => (
          <label class="checkbox-label">
            <input type="checkbox" name="publisher_type" value={value} />
            {value}
          </label>
        ))}
      </div>
    </div>

    <!-- Domain (multiples - checkboxes) -->
    <div class="form-group">
      <label>Domains *</label>
      <div class="checkbox-group">
        {domains.map(domain => (
          <label class="checkbox-label">
            <input
              type="checkbox"
              name="domain"
              value={domain}
            />
            {domain}
          </label>
        ))}
      </div>
    </div>

    <!-- Content Type (multiples - checkboxes) -->
    <div class="form-group">
      <label>Content Types *</label>
      <div class="checkbox-group">
        {contentTypes.map(type => (
          <label class="checkbox-label">
            <input
              type="checkbox"
              name="content_type"
              value={type}
            />
            {type}
          </label>
        ))}
      </div>
    </div>

    <!-- Topic (multiples - checkboxes) -->
    <div class="form-group">
      <label>Topics *</label>
      <div class="checkbox-group">
        {topics.map(topic => (
          <label class="checkbox-label">
            <input
              type="checkbox"
              name="topic"
              value={topic}
            />
            {topic}
          </label>
        ))}
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Add Resource</button>
      <button type="reset" class="btn btn-secondary">Clear</button>
    </div>
  </form>

  <!-- Success message -->
  <div id="successMsg" class="success-message" style="display: none;">
    ✅ Resource added! Scroll down to see it in the table.
  </div>

  <!-- Error message -->
  <div id="errorMsg" class="error-message" style="display: none;"></div>
</div>

<style>
  .add-resource-form {
    max-width: 600px;
    margin: 2rem auto;
    padding: 2rem;
    background: var(--lavender-mist);
    border-radius: var(--radius-card);
    border: 1px solid var(--hairline);
  }

  h2 {
    margin-top: 0;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  label {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  input[type="url"],
  input[type="text"],
  textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-badge);
    font-size: 1rem;
    font-family: var(--font-body);
    box-sizing: border-box;
  }

  input[type="url"]:focus,
  textarea:focus {
    outline: none;
    border-color: var(--indigo);
    box-shadow: 0 0 0 3px rgba(63, 43, 255, 0.12);
  }

  .checkbox-group {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.75rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: normal;
    cursor: pointer;
  }

  input[type="checkbox"] {
    cursor: pointer;
  }

  .form-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  /* Boutons : voir le pattern global src/styles/buttons.css
     (.btn + .btn-primary / .btn-secondary, conforme au composant Figma) */

  .success-message {
    margin-top: 1rem;
    padding: 1rem;
    background: rgba(72, 166, 107, 0.12);
    color: var(--positive);
    border-radius: var(--radius-badge);
    border: 1px solid rgba(72, 166, 107, 0.4);
  }

  .error-message {
    margin-top: 1rem;
    padding: 1rem;
    background: rgba(217, 74, 74, 0.12);
    color: var(--negative);
    border-radius: var(--radius-badge);
    border: 1px solid rgba(217, 74, 74, 0.4);
  }

  @media (max-width: 768px) {
    .add-resource-form {
      margin: 1rem;
      padding: 1.5rem;
    }

    .checkbox-group {
      grid-template-columns: 1fr;
    }

    .form-actions {
      flex-direction: column;
    }
  }
</style>

<script>
  let form: HTMLFormElement | null;
  let submitBtn: HTMLButtonElement | null;
  let successMsg: HTMLElement | null;
  let errorMsg: HTMLElement | null;

  const ADD_RESOURCE_ENDPOINT = '/api/add-resource';
  const PASSWORD_STORAGE_KEY = 'ux_research_admin_password';

  function initializeForm() {
    form = document.getElementById('addResourceForm') as HTMLFormElement | null;
    submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    successMsg = document.getElementById('successMsg');
    errorMsg = document.getElementById('errorMsg');

    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        addResource();
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeForm);
  } else {
    initializeForm();
  }

  function getCheckedValues(name: string): string[] {
    return Array.from(
      document.querySelectorAll<HTMLInputElement>(`input[name="${name}"]:checked`)
    ).map((el) => el.value);
  }

  function showError(message: string) {
    if (!errorMsg) return;
    errorMsg.textContent = `❌ ${message}`;
    errorMsg.style.display = 'block';
  }

  function resetSubmitButton() {
    if (!submitBtn) return;
    submitBtn.textContent = 'Add Resource';
    submitBtn.disabled = false;
  }

  async function addResource() {
    if (!form || !submitBtn || !successMsg || !errorMsg) return;

    const source = (document.getElementById('source') as HTMLInputElement).value;
    const comments = (document.getElementById('comments') as HTMLTextAreaElement).value;
    const trustLevel = parseInt(
      (document.getElementById('trust_level') as HTMLInputElement).value,
      10
    );

    const access_model = getCheckedValues('access_model');
    const origin = getCheckedValues('origin');
    const publisher_type = getCheckedValues('publisher_type');
    const domain = getCheckedValues('domain');
    const content_type = getCheckedValues('content_type');
    const topic = getCheckedValues('topic');

    if (!source) {
      showError('Source URL is required');
      return;
    }
    if (
      access_model.length === 0 ||
      origin.length === 0 ||
      publisher_type.length === 0 ||
      domain.length === 0 ||
      content_type.length === 0 ||
      topic.length === 0
    ) {
      showError('Please select at least one value in every category');
      return;
    }
    if (!Number.isInteger(trustLevel) || trustLevel < 1 || trustLevel > 5) {
      showError('Trust level must be an integer between 1 and 5');
      return;
    }

    // Auth: ask password once per browser, then keep in localStorage
    let password = localStorage.getItem(PASSWORD_STORAGE_KEY);
    if (!password) {
      password = prompt('Admin password:');
      if (!password) return;
    }

    const newResource = {
      id: `r-${Date.now()}`,
      source,
      comments: comments || '',
      access_model,
      origin,
      publisher_type,
      domain,
      content_type,
      topic,
      trust_level: trustLevel,
      last_updated: new Date().toISOString().split('T')[0],
    };

    submitBtn.textContent = '⏳ Adding...';
    submitBtn.disabled = true;
    errorMsg.style.display = 'none';

    try {
      const response = await fetch(ADD_RESOURCE_ENDPOINT, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-admin-password': password,
        },
        body: JSON.stringify(newResource),
      });

      if (response.status === 401) {
        localStorage.removeItem(PASSWORD_STORAGE_KEY);
        showError('Wrong password. Try again.');
        resetSubmitButton();
        return;
      }

      if (!response.ok) {
        const errText = await response.text();
        showError(`Server error ${response.status}: ${errText}`);
        resetSubmitButton();
        return;
      }

      // Success: remember password for next time
      localStorage.setItem(PASSWORD_STORAGE_KEY, password);
      successMsg.style.display = 'block';
      form.reset();
      resetSubmitButton();

      setTimeout(() => window.location.reload(), 1500);
    } catch (error) {
      showError(`Network error: ${(error as Error).message}`);
      resetSubmitButton();
    }
  }
</script>
