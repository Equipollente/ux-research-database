---
import '../styles/tokens.css';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Bibliographie — Psychologie cognitive et design d'expérience" />
    <title>Bibliographie — Cognitive psychologie and experience design</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>

    <!-- Navigation header -->
    <header class="nav-header">
      <p class="nav-title">UX Design &amp; Research</p>
    </header>

    <main>

      <!-- Hero -->
      <section class="hero">
        <h1 class="hero-title">Cognitive psychologie and experience design</h1>
        <h2 class="hero-subtitle">Bibliographie</h2>
      </section>

      <!-- Card content -->
      <section class="content-wrapper">
        <div class="resource-card">

          <!-- Category label -->
          <p class="category-label">Perception</p>

          <!-- Section: Académique -->
          <p class="section-label">Académique</p>
          <ul class="ref-list">
            <li>
              Wertheimer, M. (1923). Laws of Organization in Perceptual Forms (trad. anglaise).
              <em>Psychologische Forschung</em> —
              <a href="https://psychclassics.yorku.ca/Wertheimer/Forms/forms.htm" target="_blank" rel="noopener">
                psychclassics.yorku.ca
              </a> ✱
            </li>
            <li>
              Koffka, K. (1922). Perception: An introduction to the Gestalt-Theorie.
              <em>Psychological Bulletin</em> —
              <a href="https://psychclassics.yorku.ca/Koffka/Perception/perception.htm" target="_blank" rel="noopener">
                texte intégral
              </a>
            </li>
            <li>
              Treisman, A. M., &amp; Gelade, G. (1980). A feature-integration theory of attention.
              <em>Cognitive Psychology, 12(1)</em> —
              <a href="https://doi.org/10.1016/0010-0285(80)90005-5" target="_blank" rel="noopener">
                doi.org/10.1016/0010-0285(80)90005-5
              </a>
            </li>
            <li>
              Rensink, R. A., O'Regan, J. K., &amp; Clark, J. J. (1997). To see or not to see.
              <em>Psychological Science, 8(5)</em> —
              <a href="https://www2.psych.ubc.ca/~rensink/publications/download/PsychSci97-RR.pdf" target="_blank" rel="noopener">
                PDF UBC
              </a>
            </li>
            <li>
              Simons, D. J., &amp; Chabris, C. F. (1999). Gorillas in our midst.
              <em>Perception, 28(9)</em> —
              <a href="https://journals.sagepub.com/doi/10.1068/p281059" target="_blank" rel="noopener">
                Sage
              </a>
            </li>
            <li>
              Lindgaard, G., et al. (2006). You have 50 milliseconds to make a good first impression!
              <em>Behaviour &amp; Information Technology, 25(2)</em> —
              <a href="https://www.tandfonline.com/doi/abs/10.1080/01449290500330448" target="_blank" rel="noopener">
                Taylor &amp; Francis
              </a>
            </li>
            <li>
              Tractinsky, N., Katz, A. S., &amp; Ikar, D. (2000). What is beautiful is usable.
              <em>Interacting with Computers, 13(2)</em> —
              <a href="https://www.sciencedirect.com/science/article/abs/pii/S095354380000031X" target="_blank" rel="noopener">
                ScienceDirect
              </a>
            </li>
          </ul>

          <!-- Section: Industrie & Pratique -->
          <p class="section-label">Industrie &amp; Pratique</p>
          <ul class="ref-list">
            <li>
              Nielsen Norman Group — Gestalt: Proximity (Harley, 2020) —
              <a href="https://www.nngroup.com/articles/gestalt-proximity/" target="_blank" rel="noopener">
                nngroup.com
              </a>
            </li>
            <li>
              Nielsen Norman Group — Change Blindness in UX —
              <a href="https://www.nngroup.com/articles/change-blindness/" target="_blank" rel="noopener">
                nngroup.com
              </a>
            </li>
            <li>
              Nielsen Norman Group — Aesthetic-Usability Effect —
              <a href="https://www.nngroup.com/articles/aesthetic-usability-effect/" target="_blank" rel="noopener">
                nngroup.com
              </a>
            </li>
            <li>
              Laws of UX (Yablonski) — Law of Prägnanz et lois associées —
              <a href="https://lawsofux.com/law-of-pragnanz/" target="_blank" rel="noopener">
                lawsofux.com
              </a>
            </li>
            <li>
              Smashing Magazine — Visual Perception and the Principles of Gestalt —
              <a href="https://www.smashingmagazine.com/2014/03/design-principles-visual-perception-and-the-principles-of-gestalt/" target="_blank" rel="noopener">
                smashingmagazine.com
              </a>
            </li>
            <li>
              Stanford Web Credibility Project (Fogg) — 10 guidelines + étude 2002 —
              <a href="https://credibility.stanford.edu/guidelines/index.html" target="_blank" rel="noopener">
                credibility.stanford.edu
              </a>
              &nbsp;·&nbsp;
              <a href="https://simson.net/ref/2002/stanfordPTL.pdf" target="_blank" rel="noopener">
                PDF étude
              </a>
            </li>
          </ul>

        </div>

        <!-- ── 2. Affordances ─────────────────────────────────────── -->
        <div class="resource-card">
          <p class="category-label">Affordances</p>

          <p class="section-label">Académique</p>
          <ul class="ref-list">
            <li>
              Gibson, J. J. (1977). The Theory of Affordances. In <em>Perceiving, Acting, and Knowing</em>. Erlbaum —
              <a href="https://cs.brown.edu/courses/cs137/readings/Gibson-AFF.pdf" target="_blank" rel="noopener">PDF</a> ✱
            </li>
            <li>
              Norman, D. A. (2013). <em>The Design of Everyday Things</em> (Revised ed.). Basic Books —
              <a href="https://media.aanda.psu.edu/sites/media/aa/files/documents/norman_design-of-everyday-things.pdf" target="_blank" rel="noopener">extrait officiel PDF</a>
            </li>
            <li>
              IxDF — Affordances, <em>Encyclopedia of Human-Computer Interaction</em> (chapitre académique en ligne) —
              <a href="https://ixdf.org/literature/book/the-encyclopedia-of-human-computer-interaction-2nd-ed/affordances" target="_blank" rel="noopener">ixdf.org</a>
            </li>
          </ul>

          <p class="section-label">Industrie &amp; pratique</p>
          <ul class="ref-list">
            <li>
              Nielsen Norman Group — iOS 7 UX Appraisal (la perte des signifiants du flat design) —
              <a href="https://www.nngroup.com/articles/ios-7/" target="_blank" rel="noopener">nngroup.com</a>
            </li>
            <li>
              UX Planet — Affordance and Signifier (Norman expliqué) —
              <a href="https://uxplanet.org/all-about-affordance-and-signifier-terms-by-don-norman-the-ux-pioneer-e0ea7b9b99f5" target="_blank" rel="noopener">uxplanet.org</a>
            </li>
            <li>
              UX Collective — Are we even affording right? (2022) —
              <a href="https://uxdesign.cc/are-we-even-affording-right-87c02a9be502" target="_blank" rel="noopener">uxdesign.cc</a>
            </li>
            <li>
              UX Knowledge Base — Affordances &amp; Signifiers —
              <a href="https://uxknowledgebase.com/affordances-signifiers-the-4th-ux-knowledge-piece-sketch-8e1191d2bc0d" target="_blank" rel="noopener">uxknowledgebase.com</a>
            </li>
          </ul>
        </div>

        <!-- ── 3. Mémoire ─────────────────────────────────────────── -->
        <div class="resource-card">
          <p class="category-label">Mémoire</p>

          <p class="section-label">Académique</p>
          <ul class="ref-list">
            <li>
              Miller, G. A. (1956). The Magical Number Seven, Plus or Minus Two.
              <em>Psychological Review</em>, 63(2) —
              <a href="http://psychclassics.yorku.ca/Miller/" target="_blank" rel="noopener">psychclassics.yorku.ca</a> ✱
            </li>
            <li>
              Cowan, N. (2001). The magical number 4 in short-term memory.
              <em>Behavioral and Brain Sciences</em>, 24(1) —
              <a href="https://pubmed.ncbi.nlm.nih.gov/11515286/" target="_blank" rel="noopener">PubMed</a>
            </li>
            <li>
              Sweller, J. (1988). Cognitive load during problem solving.
              <em>Cognitive Science</em>, 12(2) —
              <a href="https://doi.org/10.1207/s15516709cog1202_4" target="_blank" rel="noopener">doi.org/10.1207/s15516709cog1202_4</a> ✱
            </li>
            <li>
              Roediger, H. L., &amp; Wixted, J. (2020). Recognition memory: Tulving's contributions. —
              <a href="http://psychnet.wustl.edu/memory/wp-content/uploads/2021/01/Recognition-memory-Tulvings-contributions-and-some-new-findings.pdf" target="_blank" rel="noopener">PDF</a>
            </li>
            <li>
              Paivio, A. (1986). <em>Mental Representations: A Dual Coding Approach</em> —
              <a href="https://pdfs.semanticscholar.org/a682/dc062194158c60e4c7f87a86f7e511ef3b6c.pdf" target="_blank" rel="noopener">synthèse + PDF</a>
            </li>
            <li>
              Clark, A., &amp; Chalmers, D. (1998). The Extended Mind.
              <em>Analysis</em>, 58(1) —
              <a href="http://consc.net/papers/extended.html" target="_blank" rel="noopener">consc.net</a> ✱
            </li>
          </ul>

          <p class="section-label">Industrie &amp; pratique</p>
          <ul class="ref-list">
            <li>
              Nielsen Norman Group — How Chunking Helps Content Processing —
              <a href="https://www.nngroup.com/articles/chunking/" target="_blank" rel="noopener">nngroup.com</a>
            </li>
            <li>
              Nielsen Norman Group — Working Memory and External Memory —
              <a href="https://www.nngroup.com/articles/working-memory-external-memory/" target="_blank" rel="noopener">nngroup.com</a>
            </li>
            <li>
              Nielsen Norman Group — Recognition and Recall in User Interfaces —
              <a href="https://www.nngroup.com/articles/recognition-and-recall/" target="_blank" rel="noopener">nngroup.com</a>
            </li>
            <li>
              Nielsen Norman Group — 4 Principles to Reduce Cognitive Load in Forms (2025) —
              <a href="https://www.nngroup.com/articles/4-principles-reduce-cognitive-load/" target="_blank" rel="noopener">nngroup.com</a>
            </li>
            <li>
              Laws of UX — Working Memory —
              <a href="https://lawsofux.com/working-memory/" target="_blank" rel="noopener">lawsofux.com</a>
            </li>
            <li>
              LogRocket — Progressive Disclosure in UX (2025) —
              <a href="https://blog.logrocket.com/ux-design/progressive-disclosure-ux-types-use-cases/" target="_blank" rel="noopener">blog.logrocket.com</a>
            </li>
          </ul>
        </div>

        <!-- ── 4. Modèles mentaux ──────────────────────────────────── -->
        <div class="resource-card">
          <p class="category-label">Modèles mentaux</p>

          <p class="section-label">Académique</p>
          <ul class="ref-list">
            <li>
              Jones, N. A., et al. (2011). Mental models: An interdisciplinary synthesis.
              <em>Ecology and Society</em>, 16(1), 46 — open access, couvre Craik (1943) et Johnson-Laird (1983) —
              <a href="http://www.ecologyandsociety.org/vol16/iss1/art46/" target="_blank" rel="noopener">ecologyandsociety.org</a>
            </li>
            <li>
              Gentner, D., &amp; Gentner, D. R. (1983). Flowing waters or teeming crowds: Mental models of electricity. In <em>Mental Models</em>. Erlbaum —
              <a href="https://groups.psych.northwestern.edu/gentner/papers/GentnerGentner83.pdf" target="_blank" rel="noopener">PDF Northwestern</a> ✱
            </li>
            <li>
              Norman, D. A. (2013). <em>The Design of Everyday Things</em> — modèle conceptuel designer/utilisateur —
              <a href="https://media.aanda.psu.edu/sites/media/aa/files/documents/norman_design-of-everyday-things.pdf" target="_blank" rel="noopener">extrait PDF</a>
            </li>
          </ul>

          <p class="section-label">Industrie &amp; pratique</p>
          <ul class="ref-list">
            <li>
              Nielsen Norman Group — Mental Models (Nielsen) —
              <a href="https://www.nngroup.com/articles/mental-models/" target="_blank" rel="noopener">nngroup.com</a>
            </li>
            <li>
              Software Evaluation — Mental Models in HCI —
              <a href="https://www.softwareevaluation.de/en/foundations/mental-models-in-hci/" target="_blank" rel="noopener">softwareevaluation.de</a>
            </li>
            <li>
              UX Collective — 8 Mental Model Design Heuristics —
              <a href="https://uxdesign.cc/8-mental-model-design-heuristics-85d2e3133128" target="_blank" rel="noopener">uxdesign.cc</a>
            </li>
            <li>
              Uxcel — Mental Models &amp; User Control (Apple HIG) —
              <a href="https://app.uxcel.com/courses/apple-hig/mental-models-user-control-375" target="_blank" rel="noopener">app.uxcel.com</a>
            </li>
          </ul>
        </div>

        <!-- ── 5. Motivations ─────────────────────────────────────── -->
        <div class="resource-card">
          <p class="category-label">Motivations</p>

          <p class="section-label">Académique</p>
          <ul class="ref-list">
            <li>
              Ryan, R. M., &amp; Deci, E. L. (2000). Self-Determination Theory and the facilitation of intrinsic motivation.
              <em>American Psychologist</em>, 55(1) —
              <a href="https://uvi.edu/files/documents/College_of_Liberal_Arts_and_Social_Sciences/social_sciences/OSDCD/National_Self_Determination_Richard_Ryan_and_Edward_Deci.pdf" target="_blank" rel="noopener">PDF</a>
            </li>
            <li>
              Deci, E. L., Koestner, R., &amp; Ryan, R. M. (1999). Meta-analytic review of extrinsic rewards and intrinsic motivation.
              <em>Psychological Bulletin</em>, 125(6) —
              <a href="https://doi.org/10.1037/0033-2909.125.6.627" target="_blank" rel="noopener">doi.org/10.1037/0033-2909.125.6.627</a> ✱
            </li>
            <li>
              Peters, D., Calvo, R. A., &amp; Ryan, R. M. (2018). Designing for Motivation, Engagement and Wellbeing (METUX).
              <em>Frontiers in Psychology</em>, 9, 797 —
              <a href="https://doi.org/10.3389/fpsyg.2018.00797" target="_blank" rel="noopener">doi.org/10.3389/fpsyg.2018.00797</a>
            </li>
            <li>
              Kivetz, R., Urminsky, O., &amp; Zheng, Y. (2006). The goal-gradient hypothesis resurrected.
              <em>Journal of Marketing Research</em>, 43(1) —
              <a href="https://doi.org/10.1509/jmkr.43.1.39" target="_blank" rel="noopener">doi.org/10.1509/jmkr.43.1.39</a> ✱
            </li>
          </ul>

          <p class="section-label">Industrie &amp; pratique</p>
          <ul class="ref-list">
            <li>
              Nielsen Norman Group — Autonomy, Relatedness, and Competence in UX Design —
              <a href="https://www.nngroup.com/articles/autonomy-relatedness-competence/" target="_blank" rel="noopener">nngroup.com</a>
            </li>
            <li>
              Nielsen Norman Group — The Fresh Start Effect —
              <a href="https://www.nngroup.com/articles/fresh-start-effect/" target="_blank" rel="noopener">nngroup.com</a>
            </li>
            <li>
              Laws of UX — Goal-Gradient Effect —
              <a href="https://lawsofux.com/goal-gradient-effect/" target="_blank" rel="noopener">lawsofux.com</a>
            </li>
            <li>
              Mabiloft — Micro-Steps in UX to Motivate Users —
              <a href="https://mabiloft.com/en/blog/insights/ux-and-psychology-micro-steps-in-ux-to-motivate-users" target="_blank" rel="noopener">mabiloft.com</a>
            </li>
            <li>
              Center for Self-Determination Theory — bibliothèque officielle SDT —
              <a href="https://selfdeterminationtheory.org/" target="_blank" rel="noopener">selfdeterminationtheory.org</a>
            </li>
          </ul>
        </div>

        <!-- ── 6. Biais cognitifs ──────────────────────────────────── -->
        <div class="resource-card">
          <p class="category-label">Biais cognitifs</p>

          <p class="section-label">Académique</p>
          <ul class="ref-list">
            <li>
              Tversky, A., &amp; Kahneman, D. (1974). Judgment under Uncertainty.
              <em>Science</em>, 185 —
              <a href="https://doi.org/10.1126/science.185.4157.1124" target="_blank" rel="noopener">doi.org/10.1126/science.185.4157.1124</a> ✱
            </li>
            <li>
              Kahneman, D., &amp; Tversky, A. (1979). Prospect Theory.
              <em>Econometrica</em>, 47(2) —
              <a href="https://doi.org/10.2307/1914185" target="_blank" rel="noopener">doi.org/10.2307/1914185</a> ✱
            </li>
            <li>
              Mathur, A., et al. (2019). Dark Patterns at Scale.
              <em>ACM CSCW</em> —
              <a href="https://webtransparency.cs.princeton.edu/dark-patterns/" target="_blank" rel="noopener">Princeton, paper + données</a>
            </li>
            <li>
              Parasuraman, R., &amp; Manzey, D. H. (2010). Complacency and Bias in Human Use of Automation.
              <em>Human Factors</em>, 52(3) —
              <a href="https://journals.sagepub.com/doi/10.1177/0018720810376055" target="_blank" rel="noopener">Sage</a>
            </li>
            <li>
              Dietvorst, B. J., Simmons, J. P., &amp; Massey, C. (2015). Algorithm Aversion.
              <em>JEP: General</em>, 144(1) —
              <a href="https://marketing.wharton.upenn.edu/wp-content/uploads/2016/10/Dietvorst-Simmons-Massey-2014.pdf" target="_blank" rel="noopener">PDF Wharton</a>
            </li>
            <li>
              Freedman, J. L., &amp; Fraser, S. C. (1966). Compliance without pressure (foot-in-the-door).
              <em>JPSP</em>, 4(2) —
              <a href="https://doi.org/10.1037/h0023552" target="_blank" rel="noopener">doi.org/10.1037/h0023552</a> ✱
            </li>
          </ul>

          <p class="section-label">Industrie &amp; pratique</p>
          <ul class="ref-list">
            <li>
              Growth.Design — 106 Cognitive Biases &amp; Principles That Affect Your UX —
              <a href="https://growth.design/psychology" target="_blank" rel="noopener">growth.design</a>
            </li>
            <li>
              The Decision Lab — Biases &amp; Heuristics index —
              <a href="https://thedecisionlab.com/biases" target="_blank" rel="noopener">thedecisionlab.com</a>
            </li>
            <li>
              Deceptive Design (Brignull) — taxonomie des dark patterns —
              <a href="https://www.deceptive.design/" target="_blank" rel="noopener">deceptive.design</a>
            </li>
            <li>
              UI Patterns — Loss Aversion · Isolation Effect —
              <a href="https://ui-patterns.com/patterns/Loss-aversion" target="_blank" rel="noopener">ui-patterns.com</a>
            </li>
            <li>
              Laws of UX — Jakob's Law —
              <a href="https://lawsofux.com/jakobs-law/" target="_blank" rel="noopener">lawsofux.com</a>
            </li>
            <li>
              UX Psychology — The Algorithm Aversion Paradox —
              <a href="https://uxpsychology.substack.com/p/the-algorithm-aversion-paradox" target="_blank" rel="noopener">uxpsychology.substack.com</a>
            </li>
          </ul>
        </div>

      </section>

    </main>
  </body>
</html>

<style>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: var(--font-body);
    background-color: var(--lavender-mist);
    color: var(--fg-1);
    min-height: 100vh;
  }

  /* ── Navigation header ─────────────────────────────────────────── */
  .nav-header {
    background-color: var(--bg-default);
    border-bottom: 1px solid var(--hairline);
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--spacing-6);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .nav-title {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--t-num);
    color: var(--fg-1);
    white-space: nowrap;
  }

  /* ── Hero section ──────────────────────────────────────────────── */
  .hero {
    padding: 30px var(--spacing-8);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--t-display);
    color: var(--fg-1);
    line-height: var(--lh-tight);
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--t-h2);
    color: var(--fg-1);
    line-height: normal;
  }

  /* ── Content wrapper ───────────────────────────────────────────── */
  .content-wrapper {
    padding: 0 var(--spacing-8) var(--spacing-8);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
  }

  /* ── Resource card ─────────────────────────────────────────────── */
  .resource-card {
    background-color: var(--surface-card);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: var(--spacing-10);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  /* ── Category label (indigo, prominent) ───────────────────────── */
  .category-label {
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    font-size: var(--t-h3);
    color: var(--fg-accent);
    line-height: normal;
  }

  /* ── Section label (ink, smaller) ─────────────────────────────── */
  .section-label {
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    font-size: var(--t-label);
    color: var(--fg-1);
    line-height: normal;
    margin-top: var(--spacing-2);
  }

  /* ── Reference list ────────────────────────────────────────────── */
  .ref-list {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--t-body);
    color: var(--fg-2);
    line-height: var(--lh-body);
    list-style: disc;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ref-list a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .ref-list a:hover {
    color: var(--fg-accent);
  }

  .ref-list em {
    font-style: italic;
  }

  /* ── Responsive ────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .hero {
      padding: var(--spacing-6);
    }

    .hero-title {
      font-size: var(--t-h1);
    }

    .hero-subtitle {
      font-size: var(--t-h3);
    }

    .content-wrapper {
