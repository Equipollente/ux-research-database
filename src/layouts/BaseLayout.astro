---
import '../styles/tokens.css';
import '../styles/buttons.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "UX Research Database" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header>
      <nav class="navbar">
        <div class="nav-brand">
          <h1>UX Research Database</h1>
        </div>
        <div class="nav-actions" id="nav-actions">
          <!-- Auth buttons will be injected here -->
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; 2026 Judith Heckmann. All resources curated with care.</p>
    </footer>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: var(--font-body);
        background-color: var(--lavender-mist);
        color: var(--ink);
        line-height: 1.6;
      }

      h1,
      h2,
      h3 {
        font-family: var(--font-display);
        font-weight: 700;
        color: var(--fg-1);
      }

      header {
        border-bottom: 1px solid var(--hairline);
        background: var(--white);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .navbar {
        max-width: 1400px;
        margin: 0 auto;
        padding: var(--spacing-md);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .nav-brand h1 {
        font-size: 1.5rem;
        font-weight: 600;
      }

      .nav-actions {
        display: flex;
        gap: var(--spacing-sm);
      }

      main {
        max-width: 1400px;
        margin: 0 auto;
        padding: var(--spacing-lg);
        min-height: calc(100vh - 200px);
      }

      footer {
        border-top: 1px solid var(--hairline);
        background: var(--lavender-mist);
        padding: var(--spacing-lg);
        text-align: center;
        font-size: 0.875rem;
        color: var(--slate);
      }

      @media (max-width: 768px) {
        main {
          padding: var(--spacing-md);
        }

        .navbar {
          flex-direction: column;
          gap: var(--spacing-md);
        }

        .nav-brand h1 {
          font-size: 1.25rem;
        }
      }
    </style>
  </body>
</html>
